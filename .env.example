# ── Cliente (variáveis públicas — prefixo VITE_ exposto no browser) ──────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SENTRY_DSN=https://xxxx@oXXXX.ingest.sentry.io/XXXX

# ── Edge Functions — configurar via Supabase Dashboard > Edge Functions > Secrets
# (NÃO colocar no .env local — vão direto para o Supabase)

# App
APP_URL=https://nhaferia.cv

# Segurança interna (gerar com: openssl rand -base64 32)
WEBHOOK_SECRET=

# Sentry (source maps — NÃO adicionar ao Supabase, apenas CI/CD)
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug
SENTRY_AUTH_TOKEN=

# Email (Resend — https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Pagamentos SISP / Vinti4
SISP_POS_ID=
SISP_POS_AUT_CODE=
SISP_ENDPOINT=https://mc.vinti4net.cv/payments

# eFatura DNRE
EFATURA_ENV=test                          # test | production
EFATURA_CLIENT_ID=
EFATURA_CLIENT_SECRET=
EFATURA_OAUTH_URL=
EFATURA_LED_CODE=

# Servyx Labs (Transmissor certificado DNRE)
SERVYX_NIF=
SERVYX_NAME=Servyx Labs
SERVYX_ADDRESS=
SERVYX_PRIVATE_KEY_PEM=                   # certificado ICP-CV (opcional em ambiente test)
SERVYX_CERT_PEM=
